# Azure Configuration
# Copy this file to .env and fill in your values
# Run 'npm start' for interactive setup, or configure manually below

# Required: Your Azure Subscription ID
# Find it: az account show --query id -o tsv
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# Required: Your Azure Tenant ID  
# Find it: az account show --query tenantId -o tsv
AZURE_TENANT_ID=your-tenant-id-here

# Optional: Override analysis settings (defaults in config/default.json)
# HISTORICAL_DAYS=90
# FORECAST_DAYS=30
# ANOMALY_THRESHOLD_PERCENT=20

# Cost Management API reliability controls
# Enforce live-only data (no synthetic fallback)
AZURE_COST_LIVE_DATA_ONLY=true

# Conservative throttling policy (slower but safer)
# Delay between Cost Management queries in milliseconds
AZURE_COST_API_DELAY_MS=5000

# Max retry attempts when API throttles (429)
AZURE_COST_MAX_RETRIES=5

# Exponential backoff base delay (ms)
AZURE_COST_RETRY_BASE_DELAY_MS=15000

# Max backoff delay cap (ms)
AZURE_COST_RETRY_MAX_DELAY_MS=120000
